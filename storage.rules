rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/(jpeg|jpg|png|webp)');
    }

    function isValidPdf() {
      return request.resource.contentType == 'application/pdf';
    }

    function isValidSize() {
      return request.resource.size < 10 * 1024 * 1024;
    }

    function labOrderDoc(orderId) {
      return get(/databases/(default)/documents/labOrders/$(orderId));
    }

    function canReadLabResult(orderId) {
      return isAdmin() ||
        (isSignedIn() &&
          labOrderDoc(orderId).data.userId == request.auth.uid);
    }

    match /prescriptions/{userId}/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isValidSize() && isValidImage();
    }

    match /lab_results/{orderId}/{fileName} {
      allow read: if canReadLabResult(orderId);
      allow write: if isAdmin() && isValidSize() && isValidPdf();
    }

    match /medicines/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
